#include <stdio.h>

int IP[64] = {
58,50,42,34,26,18,10,2,
60,52,44,36,28,20,12,4,
62,54,46,38,30,22,14,6,
64,56,48,40,32,24,16,8,
57,49,41,33,25,17,9,1,
59,51,43,35,27,19,11,3,
61,53,45,37,29,21,13,5,
63,55,47,39,31,23,15,7
};


unsigned long feistel(unsigned long r, unsigned long k) {
return r ^ k;
}

unsigned long apply_ip(unsigned long input) {
unsigned long output = 0;

for(int i = 0; i < 64; i++) {  
    int pos = IP[i] - 1;  
    unsigned long bit = (input >> (63 - pos)) & 1;  
    output |= (bit << (63 - i));  
}  

return output;

}

int main() {
unsigned long plaintext = 0x0123456789ABCDEF;
unsigned long key = 0x133457799BBCDFF1;

printf("Original Plaintext: %016lX\n", plaintext);  


unsigned long permuted = apply_ip(plaintext);  

  
unsigned long left = (permuted >> 32) & 0xFFFFFFFF;  
unsigned long right = permuted & 0xFFFFFFFF;  

printf("\nAfter Initial Permutation: L0 = %08lX, R0 = %08lX", left, right);  
 
for(int i = 1; i <= 16; i++) {  
    unsigned long temp = right;  
    right = left ^ feistel(right, key);  
    left = temp;  

    printf("\nRound %2d: L = %08lX, R = %08lX", i, left, right);  
}  

unsigned long ciphertext = (right << 32) | left;  

printf("\n\nCiphertext: %016lX\n", ciphertext);  

return 0;

}
